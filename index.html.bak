<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>My Website</title>
  <link rel="stylesheet" href="./style.css">
  <meta name="description" content="A simple GitHub Pages site for MyWebsite.">
</head>
<body>
  <header>
    <h1>My Website</h1>
    <p>Welcome — this is a simple GitHub Pages site. Edit files in the <code>MyWebsite/</code> folder.</p>
      <nav>
        <ul>
          <li><a href="/bio.html">Bio</a></li>
          <li><a href="/index.md">Home</a></li>
          <li><a href="/blog.html">Blog</a></li>
        </ul>
      </nav>
  </header>

  <main>
      <section>
        <h2>Welcome</h2>
        <p>Check out my <a href="/bio.html">Bio</a> or read my <a href="/blog.html">Blog</a>!</p>
      </section>
  </main>

  <footer>
    <p>Built with GitHub Pages.</p>
  </footer>
</body>
</html>
